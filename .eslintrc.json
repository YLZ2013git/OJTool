{
  "env": {
    "node": true,
    "commonjs": true,
    "es2021": true
  },
  "extends": [
    "eslint:recommended",
    "plugin:node/recommended"
  ],
  "parserOptions": {
    "ecmaVersion": 2021
  },
  "settings": {
    "node": {
      "version": ">=14.0.0"
    }
  },
  "rules": {
    "no-process-exit": "off",
    "node/no-process-exit": "off"
  }
}
